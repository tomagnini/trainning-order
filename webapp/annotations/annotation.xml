<edmx:Edmx xmlns:edmx="http://docs.oasis-open.org/odata/ns/edmx" Version="4.0">
    <edmx:Reference Uri="https://sap.github.io/odata-vocabularies/vocabularies/Communication.xml">
        <edmx:Include Namespace="com.sap.vocabularies.Communication.v1" Alias="Communication"/>
    </edmx:Reference>
    <edmx:Reference Uri="https://sap.github.io/odata-vocabularies/vocabularies/UI.xml">
        <edmx:Include Namespace="com.sap.vocabularies.UI.v1" Alias="UI"/>
    </edmx:Reference>
 <edmx:Reference Uri="https://sap.github.io/odata-vocabularies/vocabularies/Common.xml">
        <edmx:Include Namespace="com.sap.vocabularies.Common.v1" Alias="Common"/>
    </edmx:Reference>
     <edmx:Reference Uri="https://oasis-tcs.github.io/odata-vocabularies/vocabularies/Org.OData.Capabilities.V1.xml">
        <edmx:Include Namespace="Org.OData.Capabilities.V1" Alias="Capabilities"/>
    </edmx:Reference>
    <edmx:Reference Uri="/V2/Northwind/Northwind.svc/$metadata">
        <edmx:Include Namespace="NorthwindModel"/>
        <edmx:Include Namespace="ODataWeb.Northwind.Model"/>
    </edmx:Reference>
    <edmx:DataServices>
        <Schema xmlns="http://docs.oasis-open.org/odata/ns/edm" Namespace="local">
            <Annotations Target="NorthwindModel.Order">
                <Annotation Term="Common.SemanticKey">
                    <Collection>
                        <PropertyPath>OrderID</PropertyPath>
                    </Collection>
                </Annotation>
                <Annotation Term="UI.LineItem">
                    <!-- Criticidade da LINHA inteira (cor na borda esquerda).
                         ShipVia = 1/2/3 -> Vermelho/Amarelo/Verde (didático!) -->
                    <Annotation Term="UI.Criticality" Path="ShipVia"/>
                    <Collection>
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="OrderID"/>
                            <Annotation Term="UI.Importance" EnumMember="UI.ImportanceType/High"/>
                        </Record>
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="CustomerID"/>
                            <Annotation Term="UI.Importance" EnumMember="UI.ImportanceType/High"/>
                        </Record>
                        <!-- Contato com QuickView (popup) vindo da entidade Customer -->
                        <Record Type="UI.DataFieldForAnnotation">
                            <PropertyValue Property="Label" String="{@i18n>contato}"/>
                            <PropertyValue Property="Target" AnnotationPath="Customer/@Communication.Contact"/>
                            <Annotation Term="UI.Importance" EnumMember="UI.ImportanceType/Medium"/>
                        </Record>
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="OrderDate"/>
                            <Annotation Term="UI.Importance" EnumMember="UI.ImportanceType/Medium"/>
                        </Record>
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="ShippedDate"/>
                            <Annotation Term="UI.Importance" EnumMember="UI.ImportanceType/Low"/>
                        </Record>
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="Freight"/>
                            <Annotation Term="UI.Importance" EnumMember="UI.ImportanceType/Medium"/>
                        </Record>
                        <!-- DataPoint com barra de progresso dentro da tabela -->
                        <Record Type="UI.DataFieldForAnnotation">
                            <PropertyValue Property="Label" String="{@i18n>progressoFrete}"/>
                            <PropertyValue Property="Target" AnnotationPath="@UI.DataPoint#ProgressoFrete"/>
                            <Annotation Term="UI.Importance" EnumMember="UI.ImportanceType/Low"/>
                        </Record>
                        <!-- DataPoint com estrelas (rating) dentro da tabela -->
                        <Record Type="UI.DataFieldForAnnotation">
                            <PropertyValue Property="Label" String="{@i18n>avaliacao}"/>
                            <PropertyValue Property="Target" AnnotationPath="@UI.DataPoint#Avaliacao"/>
                            <Annotation Term="UI.Importance" EnumMember="UI.ImportanceType/Low"/>
                        </Record>
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="ShipCountry"/>
                            <Annotation Term="UI.Importance" EnumMember="UI.ImportanceType/Medium"/>
                        </Record>
                    </Collection>
                </Annotation>
                <Annotation Term="UI.SelectionFields">
                    <Collection>
                        <PropertyPath>OrderID</PropertyPath>
                        <PropertyPath>CustomerID</PropertyPath>
                        <PropertyPath>OrderDate</PropertyPath>
                        <PropertyPath>ShipCountry</PropertyPath>
                        <PropertyPath>ShippedDate</PropertyPath>
                    </Collection>
                </Annotation>
                <Annotation Term="UI.FieldGroup" Qualifier="DadosGerais">
                    <Record Type="UI.FieldGroupType">
                        <PropertyValue Property="Data">
                            <Collection>
                                <Record Type="UI.DataField">
                                    <PropertyValue Property="Value" Path="OrderID"/>
                                </Record>
                                <Record Type="UI.DataField">
                                    <PropertyValue Property="Value" Path="OrderDate"/>
                                </Record>
                                <Record Type="UI.DataField">
                                    <PropertyValue Property="Value" Path="CustomerID"/>
                                </Record>
                                <Record Type="UI.DataField">
                                    <PropertyValue Property="Value" Path="EmployeeID"/>
                                </Record>
                                <Record Type="UI.DataField">
                                    <PropertyValue Property="Value" Path="Customer/CompanyName"/>
                                </Record>
                            </Collection>
                        </PropertyValue>
                        <PropertyValue Property="Label" String="{@i18n>dadosGerais}"/>
                    </Record>
                </Annotation>
                <Annotation Term="UI.Facets">
                    <Collection>
                        <Record Type="UI.ReferenceFacet">
                            <PropertyValue Property="Label" String="{@i18n>dadosGerais}"/>
                            <PropertyValue Property="ID" String="dadosgerais"/>
                            <PropertyValue Property="Target" AnnotationPath="@UI.FieldGroup#DadosGerais"/>
                        </Record>
                        <Record Type="UI.ReferenceFacet">
                            <PropertyValue Property="Label" String="DadosGerais"/>
                            <PropertyValue Property="ID" String="dadosgerais2"/>
                            <PropertyValue Property="Target" AnnotationPath="@UI.FieldGroup#DadosGerais"/>
                        </Record>
                        <Record Type="UI.ReferenceFacet">
                            <PropertyValue Property="Target" AnnotationPath="Order_Details/@UI.LineItem"/>
                            <PropertyValue Property="Label" String="Itens"/>
                            <PropertyValue Property="ID" String="Itens"/>
                        </Record>
                    </Collection>
                </Annotation>
            </Annotations>
             <!-- ============================================================ -->
            <!-- 2. ANNOTATIONS DE PROPRIEDADES (labels, texto, value help)    -->
            <!-- ============================================================ -->
            <Annotations Target="NorthwindModel.Order/OrderID">
                <Annotation Term="Common.Label" String="{@i18n>ordem}"/>
            </Annotations>
            <!-- ============================================================ -->
            <!-- 5. CAPABILITIES: as ações CRUD (Criar/Editar/Eliminar) ficam  -->
            <!--    ATIVAS. Só desligamos a busca livre ($search), que o       -->
            <!--    Northwind não suporta e geraria erro na requisição.        -->
            <!--    Obs.: o Northwind público é read-only, então gravações     -->
            <!--    retornam erro do servidor - ótimo para demonstrar o        -->
            <!--    tratamento de mensagens do Fiori Elements.                 -->
            <!-- ============================================================ -->
            <Annotations Target="ODataWeb.Northwind.Model.NorthwindEntities/Orders">
                <Annotation Term="Capabilities.SearchRestrictions">
                    <Record>
                        <PropertyValue Property="Searchable" Bool="false"/>
                    </Record>
                </Annotation>
            </Annotations>
            <!-- Colunas da tabela do List Report -->
                
                <!-- SemanticKey: OrderID aparece em destaque (negrito) na tabela -->

            <Annotations Target="NorthwindModel.Order_Detail">
                <Annotation Term="UI.LineItem">
                    <Collection>
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="ProductID"/>
                            <Annotation Term="UI.Importance" EnumMember="UI.ImportanceType/High"/>
                        </Record>
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="UnitPrice"/>
                        </Record>
                        <Record Type="UI.DataField">
                            <PropertyValue Property="Value" Path="Quantity"/>
                        </Record>
                    </Collection>
                </Annotation>
            </Annotations>
        </Schema>
    </edmx:DataServices>
</edmx:Edmx>